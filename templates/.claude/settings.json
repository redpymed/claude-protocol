{
  "$schema": "https://claude.ai/schemas/settings.json",
  "_comment": "Configuración mínima de Claude Code. Ajusta según tu stack. Ver normasClaudeCode.md §9.",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(pnpm install)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(claude-protocol *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/**)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "_comment": "Activar hooks deterministas. Ver normasClaudeCode.md §3.",
    "PreToolUse": [],
    "PostToolUse": []
  }
}
